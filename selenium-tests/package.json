{
  "name": "smart-learn-selenium-tests",
  "version": "1.0.0",
  "description": "Selenium WebDriver E2E Test Suite for Smart Learn frontend (305 test cases)",
  "scripts": {
    "test": "mocha tests/login.test.js --timeout 60000 --exit",
    "test:auth": "mocha tests/login.test.js --timeout 60000 --exit --grep 'MODULE 1'",
    "test:navigation": "mocha tests/login.test.js --timeout 60000 --exit --grep 'MODULE 2'",
    "test:home": "mocha tests/login.test.js --timeout 60000 --exit --grep 'MODULE 3'",
    "test:courses": "mocha tests/login.test.js --timeout 60000 --exit --grep 'MODULE 4'",
    "test:tutor": "mocha tests/login.test.js --timeout 60000 --exit --grep 'MODULE 5'",
    "test:progress": "mocha tests/login.test.js --timeout 60000 --exit --grep 'MODULE 6'",
    "test:profile": "mocha tests/login.test.js --timeout 60000 --exit --grep 'MODULE 7'",
    "test:settings": "mocha tests/login.test.js --timeout 60000 --exit --grep 'MODULE 8'",
    "test:ux": "mocha tests/login.test.js --timeout 60000 --exit --grep 'MODULE 9'",
    "test:headless": "HEADLESS=true mocha tests/login.test.js --timeout 60000 --exit",
    "generate:report": "python generate_excel.py"
  },
  "dependencies": {
    "chai": "^4.3.10",
    "mocha": "^10.4.0",
    "selenium-webdriver": "^4.20.0"
  },
  "devDependencies": {
    "chromedriver": "^126.0.0",
    "mochawesome": "^7.1.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "selenium",
    "e2e",
    "testing",
    "webdriver",
    "smart-learn",
    "automated-testing"
  ],
  "author": "Smart Learn QA Team",
  "license": "MIT"
}
