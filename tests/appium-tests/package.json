{
  "name": "smart-learn-appium-tests",
  "version": "1.0.0",
  "description": "E2E Appium test suite for Smart Learn Companion mobile application",
  "scripts": {
    "pretest": "rm -rf node_modules/ts-node || rmdir /s /q node_modules\\ts-node || true",
    "test": "npx wdio run wdio.conf.js",
    "test:ci": "node run-ci-tests.js",
    "test:auth": "npx wdio run wdio.conf.js --spec tests/auth.spec.js",
    "test:home": "npx wdio run wdio.conf.js --spec tests/home.spec.js",
    "test:courses": "npx wdio run wdio.conf.js --spec tests/courses.spec.js",
    "test:tutor": "npx wdio run wdio.conf.js --spec tests/tutor.spec.js",
    "test:progress": "npx wdio run wdio.conf.js --spec tests/progress.spec.js",
    "test:profile": "npx wdio run wdio.conf.js --spec tests/profile.spec.js",
    "test:settings": "npx wdio run wdio.conf.js --spec tests/settings.spec.js",
    "test:navigation": "npx wdio run wdio.conf.js --spec tests/navigation.spec.js",
    "report": "node utils/generateReport.js"
  },
  "dependencies": {
    "@wdio/appium-service": "^8.0.0",
    "@wdio/cli": "^8.0.0",
    "@wdio/jasmine-framework": "^8.0.0",
    "@wdio/local-runner": "^8.0.0",
    "@wdio/spec-reporter": "^8.0.0",
    "appium": "^2.11.0",
    "appium-uiautomator2-driver": "^3.0.0",
    "chai": "^4.3.10"
  },
  "devDependencies": {
    "@wdio/allure-reporter": "^8.0.0"
  }
}
