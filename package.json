{
  "name": "smart-learning-companion",
  "version": "1.0.0",
  "description": "AI-Driven Smart Learning Companion: A Federated Learning Approach for Privacy-Preserving Personalized Academic Guidance.",
  "author": "Smart Learn Team <team@smartlearn.edu>",
  "main": "app/main/electron-main.js",
  "scripts": {
    "dev": "node backend/server.js",
    "start": "electron app/main/electron-main.js",
    "build": "electron-builder",
    "build-mobile": "node scripts/build-mobile.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.smartlearn.companion",
    "productName": "Smart Learn",
    "copyright": "Copyright © 2026 Smart Learn",
    "npmRebuild": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!dist/**",
      "!*.log",
      "!scripts/peek_db.js",
      "!scripts/make-icon.js"
    ],
    "asarUnpack": [
      "node_modules/sqlite3/**",
      "node_modules/express/**",
      "backend/server.js",
      "database/smart_learn.db",
      "frontend/utils/db.js",
      "frontend/utils/auth.js",
      "frontend/utils/ai.js",
      "frontend/utils/federated.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Smart Learn"
    }
  }
}
